{
  "name": "workflow-agent",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "workflow-agent",
      "workspaces": [
        "packages/*"
      ],
      "dependencies": {
        "commander": "^13.1.0"
      }
    },
    "node_modules/@workflow-agent/agent": {
      "resolved": "packages/agent",
      "link": true
    },
    "node_modules/@workflow-agent/cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/@workflow-agent/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@workflow-agent/dashboard": {
      "resolved": "packages/dashboard",
      "link": true
    },
    "node_modules/commander": {
      "version": "13.1.0",
      "resolved": "https://registry.npmmirror.com/commander/-/commander-13.1.0.tgz",
      "integrity": "sha512-/rFeCpNJQbhSZjGVwO9RFV3xPqbnERS8MmIQzCtD/zl6gpJuV/bMLuN92oG3F7d8oDEHHRrujSXNUr8fpjntKw==",
      "license": "MIT",
      "engines": {
        "node": ">=18"
      }
    },
    "packages/agent": {
      "name": "@workflow-agent/agent",
      "version": "0.1.0"
    },
    "packages/cli": {
      "name": "@workflow-agent/cli",
      "version": "0.1.0",
      "dependencies": {
        "@workflow-agent/agent": "0.1.0",
        "@workflow-agent/core": "0.1.0"
      },
      "bin": {
